---
import { Icon } from "astro-icon/components";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="页面不存在" description="请求的页面不存在">
    <section class="card-base px-6 py-10 md:px-10 md:py-14 text-center">
        <div class="mx-auto flex size-14 items-center justify-center rounded-full bg-[var(--btn-regular-bg)] text-[var(--primary)]">
            <Icon name="material-symbols:search-off-rounded" class="text-3xl" />
        </div>
        <p class="mt-5 text-sm font-medium text-[var(--primary)]">404</p>
        <h1 class="mt-2 text-2xl font-bold text-[var(--title-active)]">页面不存在</h1>
        <p class="mx-auto mt-3 max-w-md text-[var(--text-50)]">
            这个地址可能已经失效，或者页面已被移动。
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
            <a href="/" class="btn-regular px-5 py-2.5 font-medium">返回首页</a>
            <a href="/projects/" class="btn-regular px-5 py-2.5 font-medium">查看项目</a>
        </div>
    </section>
</MainGridLayout>
