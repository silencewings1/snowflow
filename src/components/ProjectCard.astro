---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import ImageWrapper from "./misc/ImageWrapper.astro";

interface Props {
	entry: CollectionEntry<"projects">;
	class?: string;
	style?: string;
}
const { entry, style } = Astro.props;
const className = Astro.props.class;
const { title, description, image, url, embedded, status, tags } = entry.data;

const hasCover = image !== undefined && image !== null && image !== "";

// 内嵌项目（同域子路径）：同窗口跳转，不显示外链图标
const linkTarget = embedded ? "_self" : "_blank";
const linkRel = embedded ? undefined : "noopener";

// 状态标签文案与配色
const statusMap = {
	ongoing: { text: "进行中", color: "text-[var(--primary)]" },
	completed: { text: "已完成", color: "text-emerald-500" },
	archived: { text: "已归档", color: "text-black/40 dark:text-white/40" },
} as const;
const statusInfo = statusMap[status];
---
<div class:list={["card-base flex flex-col w-full rounded-[var(--radius-large)] overflow-hidden relative group onload-animation", className]} style={style}>
    {hasCover && (
        <a href={url} target={linkTarget} rel={linkRel} aria-label={title}
           class="block relative w-full aspect-[16/9] overflow-hidden active:scale-95 transition">
            <div class="absolute pointer-events-none z-10 w-full h-full group-hover:bg-black/30 group-active:bg-black/50 transition"></div>
            <div class="absolute pointer-events-none z-20 w-full h-full flex items-center justify-center">
                {!embedded && (
                    <Icon name="fa6-solid:arrow-up-right-from-square"
                          class="transition opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 text-white text-4xl">
                    </Icon>
                )}
                {embedded && (
                    <Icon name="fa6-solid:arrow-right"
                          class="transition opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 text-white text-4xl">
                    </Icon>
                )}
            </div>
            <ImageWrapper src={image} basePath="content/projects/" alt={`Cover of ${title}`}
                          class="w-full h-full" format="webp" widths={[320, 480, 640, 800, 960]}
                          sizes="(min-width: 1024px) 432px, (min-width: 768px) calc(50vw - 2rem), calc(100vw - 2rem)">
            </ImageWrapper>
        </a>
    )}
    <div class="px-6 md:px-7 pt-5 pb-6 flex flex-col flex-1">
        <div class="flex items-center gap-2 mb-2">
            <a href={url} target={linkTarget} rel={linkRel}
               class="transition font-bold text-2xl text-90 hover:text-[var(--primary)] dark:hover:text-[var(--primary)] active:text-[var(--title-active)] dark:active:text-[var(--title-active)] flex items-center gap-1">
                {title}
                {!embedded && (
                    <Icon class="text-[var(--primary)] text-base -translate-y-0.5" name="fa6-solid:arrow-up-right-from-square"></Icon>
                )}
            </a>
        </div>
        <div class:list={["text-xs font-medium mb-3", statusInfo.color]}>
            {statusInfo.text}
        </div>
        {description && (
            <div class="text-75 text-sm mb-4 pr-2 flex-1">{description}</div>
        )}
        {tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
                {tags.map((t) => (
                    <span class="text-xs px-2 py-0.5 rounded-md bg-[var(--enter-btn-bg)] text-50">{t}</span>
                ))}
            </div>
        )}
    </div>
</div>
